{
  "categories": [
    { "id": "basic", "label": "Basic", "description": "Ramping rate with mixed protocols for baseline latency." },
    { "id": "body_size", "label": "Body Size", "description": "Fixed rate with larger payloads to observe payload scaling." },
    { "id": "stress", "label": "Stress", "description": "High-QPS stress stages for ingress and egress under pressure." }
  ],
  "metrics": [
    { "id": "cpu",           "label": "CPU Usage",          "unit": "%" },
    { "id": "rss",           "label": "Memory RSS",         "unit": "MB" },
    { "id": "vms",           "label": "Virtual Memory",     "unit": "MB" },
    { "id": "net_rx_kbs",    "label": "Network RX",         "unit": "KB/s" },
    { "id": "net_tx_kbs",    "label": "Network TX",         "unit": "KB/s" },
    { "id": "tcp_estab",     "label": "TCP Established",    "unit": "conns" },
    { "id": "loadavg_1",     "label": "Load Average (1m)",  "unit": "" },
    { "id": "psi_cpu_some",  "label": "PSI CPU Some",       "unit": "%" },
    { "id": "psi_cpu_full",  "label": "PSI CPU Full",       "unit": "%" },
    { "id": "psi_mem_some",  "label": "PSI Memory Some",    "unit": "%" },
    { "id": "psi_mem_full",  "label": "PSI Memory Full",    "unit": "%" },
    { "id": "psi_io_some",   "label": "PSI IO Some",        "unit": "%" },
    { "id": "psi_io_full",   "label": "PSI IO Full",        "unit": "%" }
  ],
  "groups": [
    { "id": "server",    "label": "DuoTunnel Server" },
    { "id": "client",    "label": "DuoTunnel Client" },
    { "id": "ctld",      "label": "DuoTunnel Control" },
    { "id": "http_echo", "label": "HTTP Echo" },
    { "id": "ws_echo",   "label": "WS Echo" },
    { "id": "grpc_echo", "label": "gRPC Echo" },
    { "id": "k6",        "label": "k6" },
    { "id": "frps",      "label": "FRP Server" },
    { "id": "frpc",      "label": "FRP Client" },
    { "id": "other",     "label": "Other" }
  ],
  "process_mapping": [
    { "prefix": "server",          "group": "server" },
    { "prefix": "client",          "group": "client" },
    { "prefix": "tunnel-ctld",      "group": "ctld" },
    { "prefix": "ctld",            "group": "ctld" },
    { "prefix": "http-echo-server","group": "http_echo" },
    { "prefix": "http-echo-serve", "group": "http_echo" },
    { "prefix": "ws-echo-server",  "group": "ws_echo" },
    { "prefix": "ws-echo-serve",   "group": "ws_echo" },
    { "prefix": "grpc-echo-server","group": "grpc_echo" },
    { "prefix": "grpc-echo-serve", "group": "grpc_echo" },
    { "prefix": "k6",              "group": "k6" },
    { "prefix": "frps",            "group": "frps" },
    { "prefix": "frpc",            "group": "frpc" }
  ]
}
